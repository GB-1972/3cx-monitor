# Copy to .env on the Docker host and change all values.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password
APP_SECRET_KEY=change-this-to-a-long-random-secret
DATABASE_URL=postgresql+psycopg://3cxmonitor:change-this-db-password@postgres:5432/3cxmonitor
POLL_INTERVAL_SECONDS=30
REQUEST_TIMEOUT_SECONDS=12
CORS_ORIGINS=http://localhost:5173,http://localhost:8088
POSTGRES_DB=3cxmonitor
POSTGRES_USER=3cxmonitor
POSTGRES_PASSWORD=change-this-db-password

